# Binance API (use subaccount keys for safety)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Strategy Parameters — volume & funding (defaults tuned for more frequency)
CAPITAL_PER_LEG_USD=1000
TOP_N=3
MIN_VOLUME_USD=25000000
MIN_LEG_VOLUME_RATIO=0.2
MAX_SLIPPAGE_PCT=0.002
ORDER_BOOK_LIMIT=40
MIN_FUNDING_RATE_TO_OPEN=0.00008
MIN_FUNDING_RATE_TO_HOLD=0.00004
MIN_HOLD_HOURS=24
BLACKLIST_SYMBOLS=BNB

# DynamoDB
DYNAMO_TABLE_NAME=funding-rate-arb-positions
AWS_REGION=ap-northeast-1

# Safety Modes (set to true for testing)
DRY_RUN=false
USE_TESTNET=false
